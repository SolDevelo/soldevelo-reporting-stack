# =============================================================================
# SolDevelo Reporting Stack - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Do NOT commit .env to version control.

# --- Source OpenLMIS PostgreSQL (external) ---
SOURCE_PG_HOST=localhost
SOURCE_PG_PORT=5432
SOURCE_PG_DB=open_lmis
SOURCE_PG_USER=openlmis
SOURCE_PG_PASSWORD=changeme

# --- Debezium CDC ---
SOURCE_PG_SLOT_NAME=debezium_reporting
SOURCE_PG_PUBLICATION=dbz_publication
DEBEZIUM_TOPIC_PREFIX=openlmis
# Comma-separated list of schema.table patterns to capture.
# Adjust to match your OpenLMIS database schema.
SOURCE_PG_TABLE_ALLOWLIST=referencedata.facilities,referencedata.programs,referencedata.geographic_zones,requisition.requisitions,requisition.requisition_line_items

# --- Kafka ---
# KAFKA_BOOTSTRAP_SERVERS is used by platform scripts (ClickHouse init, etc.),
# not by the compose services directly.
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EXTERNAL_PORT=9094

# --- Kafka Connect ---
CONNECT_PORT=8083

# --- Apicurio Schema Registry ---
APICURIO_URL=http://apicurio:8080
APICURIO_PORT=8085

# --- Kafka UI ---
KAFKA_UI_PORT=9080

# --- ClickHouse ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=reporting
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=changeme

# --- Superset ---
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=changeme
SUPERSET_SECRET_KEY=replace-with-a-long-random-string
SUPERSET_PORT=8088

# --- Airflow ---
AIRFLOW__CORE__FERNET_KEY=replace-with-fernet-key
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_PORT=8080

# --- Analytics Packages ---
# Path to the analytics-core package (required). Default uses the built-in OLMIS example.
ANALYTICS_CORE_PATH=examples/olmis-analytics-core
# Comma-separated paths to analytics-extension packages (optional).
# ANALYTICS_EXTENSIONS_PATHS=examples/olmis-analytics-malawi
