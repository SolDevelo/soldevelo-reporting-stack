# =============================================================================
# SolDevelo Reporting Stack - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Do NOT commit .env to version control.

# --- Source OpenLMIS PostgreSQL (external) ---
SOURCE_PG_HOST=localhost
SOURCE_PG_PORT=5432
SOURCE_PG_DB=open_lmis
SOURCE_PG_USER=openlmis
SOURCE_PG_PASSWORD=changeme

# --- Debezium CDC ---
SOURCE_PG_SLOT_NAME=debezium_reporting
SOURCE_PG_PUBLICATION=dbz_publication
DEBEZIUM_TOPIC_PREFIX=openlmis
# Comma-separated list of schema.table patterns to capture.
# Adjust to match your OpenLMIS database schema.
SOURCE_PG_TABLE_ALLOWLIST=referencedata.facilities,referencedata.programs,referencedata.geographic_zones,requisition.requisitions,requisition.requisition_line_items

# --- Kafka ---
# Broker address as seen from INSIDE the Docker network (used in ClickHouse Kafka
# engine DDL and dbt container networking). Do NOT change to localhost — this value
# is embedded in ClickHouse table definitions, not used by host-side scripts directly.
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EXTERNAL_PORT=9094

# --- Kafka Connect ---
CONNECT_PORT=8083

# --- Apicurio Schema Registry ---
APICURIO_URL=http://apicurio:8080
APICURIO_PORT=8085

# --- Kafka UI ---
KAFKA_UI_PORT=9080

# --- ClickHouse ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=reporting
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=changeme
# Override ClickHouse hostname for host-side scripts (e.g., remote ClickHouse deployments).
# CLICKHOUSE_HOST_EXTERNAL=localhost

# --- ClickHouse Raw Landing (optional) ---
# Explicit topic list; if unset, derived from SOURCE_PG_TABLE_ALLOWLIST + DEBEZIUM_TOPIC_PREFIX.
# RAW_KAFKA_TOPICS=openlmis.referencedata.facilities,openlmis.referencedata.programs
# Retention period for raw events tables in days. Set to 0 to disable TTL.
# RAW_TTL_DAYS=90

# --- Superset (planned — not yet deployed) ---
# These variables are reserved for the Superset service (Task 6).
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=changeme
SUPERSET_SECRET_KEY=replace-with-a-long-random-string
SUPERSET_PORT=8088

# --- Airflow ---
# Generate a Fernet key: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=replace-with-fernet-key
AIRFLOW_PORT=8080
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# DAG schedule for platform_refresh (cron or preset like @hourly)
# AIRFLOW_REFRESH_SCHEDULE=@hourly
# Max age in minutes for raw data freshness check (skip dbt if stale)
# FRESHNESS_MAX_AGE_MINUTES=60

# --- Reporting Host Root (required for Airflow) ---
# Absolute host path to this repo root. Airflow runs dbt via Docker socket,
# and Docker resolves volume mount paths on the host, not inside the container.
# Without this, scheduled dbt runs will fail.
REPORTING_HOST_ROOT=/path/to/openlmis-reporting

# --- Airflow UID (Linux only) ---
# Set to your host user ID to avoid permission issues with mounted volumes.
# Run: id -u
# AIRFLOW_UID=1000

# --- Analytics Packages ---
# Path to the analytics-core package (required). Default uses the built-in OLMIS example.
ANALYTICS_CORE_PATH=examples/olmis-analytics-core
# Comma-separated paths to analytics-extension packages (optional).
# ANALYTICS_EXTENSIONS_PATHS=examples/olmis-analytics-malawi
